# Create a separate production env file
cp .env .env.production

# Edit with production values
# nano .env.production

# Environment
ENV=production
LOG_LEVEL=INFO

# Frontend - Update with your Railway frontend URL
FRONTEND_URL=https://your-frontend.railway.app

# Database - Railway provides this automatically as DATABASE_URL
# No need to set manually

# AWS Credentials - Set in Railway dashboard
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
S3_BUCKET=codexa-2026
S3_PREFIX=prototype
AWS_REGION=us-east-1

# SQS
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/657372247607/codexa-prototype

# Bedrock
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0
NOVA_MODEL_ID=amazon.nova-micro-v1:0
TITAN_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1

# Query
DEFAULT_TEACHING_MODE=explanation

# Lambda
LAMBDA_FUNCTION_NAME=codexa-analysis
LAMBDA_MODE=remote

# Cognito
COGNITO_USER_POOL_ID=us-east-1_dNGB9UtRx
COGNITO_CLIENT_ID=1fu0qbokifrchf0jsa5qf9e6c6
COGNITO_REGION=us-east-1

# Security - Generate new key with: openssl rand -hex 32
SECRET_KEY=42b592aca41dee249292c69161a8a34d952dbe6c81f715bbde9e44fbec0bbf1e
ALLOWED_HOSTS=your-backend.railway.app

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=2000

# Monitoring (optional)
SENTRY_DSN=

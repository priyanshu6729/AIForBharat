# Environment
ENV=production
LOG_LEVEL=info

# Frontend - Update with your Railway frontend URL
FRONTEND_URL=https://your-frontend.railway.app

# Database - Railway provides DATABASE_URL automatically
# No need to set manually

# AWS Credentials - DO NOT COMMIT - Set in Railway dashboard only
# These should only be set in Railway's environment variables
S3_BUCKET=codexa-2026
S3_PREFIX=prototype
AWS_REGION=us-east-1

# SQS
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/657372247607/codexa-prototype

# Bedrock
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0
NOVA_MODEL_ID=amazon.nova-micro-v1:0
TITAN_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1

# Query
DEFAULT_TEACHING_MODE=explanation

# Lambda
LAMBDA_FUNCTION_NAME=codexa-analysis
LAMBDA_MODE=remote

# Cognito
COGNITO_USER_POOL_ID=us-east-1_dNGB9UtRx
COGNITO_CLIENT_ID=1fu0qbokifrchf0jsa5qf9e6c6
COGNITO_REGION=us-east-1

# Security
SECRET_KEY=a52db4f11e156c697009b77d3a3671b88c06c2cd2c25dfa20a00d5116f0bd9ad
ALLOWED_HOSTS=codexa-backend.railway.app

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
